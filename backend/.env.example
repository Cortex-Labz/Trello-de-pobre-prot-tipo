# Database (PostgreSQL)
# Para desenvolvimento local, pode usar SQLite: DATABASE_URL="file:./dev.db" (troque provider no schema.prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/versatly_task"

# JWT
JWT_SECRET="versatly-task-super-secret-jwt-key-change-in-production-2024"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV="development"

# CORS
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,http://localhost:3001"
